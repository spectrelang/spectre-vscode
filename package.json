{
  "name": "spectre-lang",
  "displayName": "Spectre",
  "description": "Spectre Programming Language Support",
  "author": "Navid M",
  "version": "0.0.1",
  "repository": {
    "url": "https://github.com/spectrelang/spectre-vscode"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "spectre",
        "aliases": [
          "Spectre",
          "spectre"
        ],
        "extensions": [
          ".sx"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "spectre",
        "scopeName": "source.spectre",
        "path": "./syntaxes/spectre.tmLanguage.json"
      }
    ]
  }
}
