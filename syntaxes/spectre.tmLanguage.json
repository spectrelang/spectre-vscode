{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Spectre",
  "scopeName": "source.spectre",
  "fileTypes": ["sp", "spectre"],
  "patterns": [
    { "include": "#doc_comment" },
    { "include": "#line_comment" },
    { "include": "#string" },
    { "include": "#char_literal" },
    { "include": "#hex_literal" },
    { "include": "#number" },
    { "include": "#keywords" },
    { "include": "#builtin_types" },
    { "include": "#builtin_intrinsics" },
    { "include": "#type_declaration" },
    { "include": "#fn_declaration" },
    { "include": "#extern_declaration" },
    { "include": "#use_expr" },
    { "include": "#option_type" },
    { "include": "#generic_type" },
    { "include": "#ref_type" },
    { "include": "#annotation" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#constants" },
    { "include": "#identifier" }
  ],
  "repository": {
    "doc_comment": {
      "name": "comment.block.documentation.spectre",
      "begin": "///",
      "end": "$",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.comment.spectre" }
      }
    },

    "line_comment": {
      "name": "comment.line.double-slash.spectre",
      "begin": "//",
      "end": "$",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.comment.spectre" }
      }
    },

    "string": {
      "name": "string.quoted.double.spectre",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.spectre" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.spectre" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.spectre",
          "match": "\\\\(?:[nrt\\\\\"0]|x[0-9A-Fa-f]{2})"
        },
        {
          "name": "constant.other.placeholder.spectre",
          "match": "\\{[^}]*\\}"
        }
      ]
    },

    "char_literal": {
      "name": "string.quoted.single.spectre",
      "match": "'(?:[^'\\\\]|\\\\(?:[nrt\\\\']|x[0-9A-Fa-f]{2}))'"
    },

    "hex_literal": {
      "name": "constant.numeric.hex.spectre",
      "match": "\\b0x[0-9A-Fa-f]+"
    },

    "number": {
      "name": "constant.numeric.spectre",
      "match": "\\b[0-9][0-9_]*(?:\\.[0-9][0-9_]*)?"
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.spectre",
          "match": "\\b(if|else|elif|for|defer|match|when|return|assert|break|continue)\\b"
        },
        {
          "name": "keyword.declaration.spectre",
          "match": "\\b(fn|type|val|pub|extern|spec|link|enum|union|test)\\b"
        },
        {
          "name": "keyword.modifier.spectre",
          "match": "\\b(mut|trust|guarded)\\b"
        },
        {
          "name": "keyword.other.spectre",
          "match": "\\b(pre|post|use|self|some|none|ok|err|true|false)\\b"
        }
      ]
    },

    "builtin_types": {
      "name": "support.type.primitive.spectre",
      "match": "\\b(i8|i16|i32|i64|i128|u8|u16|u32|u64|u128|f32|f64|usize|isize|bool|char|void)\\b"
    },

    "builtin_intrinsics": {
      "name": "support.function.builtin.spectre",
      "match": "@(?:alloc|free|load|store|ptradd|memset|memcpy|realloc|arc4random_buf|arc4random_uniform|snprintf|assert)\\b"
    },

    "type_declaration": {
      "comment": "type Foo = { ... }  /  enum Foo = { ... }  /  union Foo = { ... }",
      "match": "\\b(type|enum|union)\\s+([A-Z][A-Za-z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.declaration.spectre" },
        "2": { "name": "entity.name.type.spectre" }
      }
    },

    "fn_declaration": {
      "comment": "pub fn (TypeName) funcName(...)  or  fn funcName(...)",
      "patterns": [
        {
          "comment": "Method syntax: fn (TypeName) methodName",
          "match": "\\b(fn)\\s+\\(([A-Za-z][A-Za-z0-9_]*)\\)\\s+([a-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.spectre" },
            "2": { "name": "entity.name.type.spectre" },
            "3": { "name": "entity.name.function.spectre" }
          }
        },
        {
          "comment": "Plain function: fn funcName",
          "match": "\\b(fn)\\s+([a-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.spectre" },
            "2": { "name": "entity.name.function.spectre" }
          }
        }
      ]
    },

    "extern_declaration": {
      "comment": "extern (C) fn name(...)",
      "match": "\\b(extern)\\s+(\\([^)]*\\))\\s+(fn)\\s+([a-z_][A-Za-z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.declaration.spectre" },
        "2": { "name": "storage.modifier.spectre" },
        "3": { "name": "keyword.declaration.spectre" },
        "4": { "name": "entity.name.function.spectre" }
      }
    },

    "use_expr": {
      "comment": "use(\"std\")",
      "match": "\\b(use)\\s*\\(\\s*(\"[^\"]*\")\\s*\\)",
      "captures": {
        "1": { "name": "keyword.other.spectre" },
        "2": { "name": "string.quoted.double.spectre" }
      }
    },

    "option_type": {
      "comment": "option[T]",
      "match": "\\b(option)\\s*\\[",
      "captures": {
        "1": { "name": "support.type.spectre" }
      }
    },

    "generic_type": {
      "comment": "TypeName[T]  — e.g. option[ref char]",
      "match": "\\b([A-Z][A-Za-z0-9_]*)\\s*\\[",
      "captures": {
        "1": { "name": "entity.name.type.spectre" }
      }
    },

    "ref_type": {
      "comment": "ref T  (type qualifier)",
      "match": "\\b(ref)\\b",
      "captures": {
        "1": { "name": "storage.modifier.spectre" }
      }
    },

    "annotation": {
      "comment": "Standalone identifier annotations like pre/post label names",
      "match": "\\b([a-z_][a-z0-9_]*)\\s*:",
      "captures": {
        "1": { "name": "variable.other.label.spectre" }
      }
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.spectre",
          "match": "=>"
        },
        {
          "name": "keyword.operator.comparison.spectre",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.spectre",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.spectre",
          "match": "\\+|\\-|\\*|\\/|%|\\^|&|\\||~|<<|>>"
        },
        {
          "name": "keyword.operator.logical.spectre",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.increment.spectre",
          "match": "\\+\\+|\\-\\-"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        { "name": "punctuation.separator.spectre", "match": "," },
        { "name": "punctuation.terminator.spectre", "match": ";" },
        { "name": "punctuation.accessor.spectre", "match": "\\." },
        { "name": "punctuation.definition.block.spectre", "match": "[{}]" },
        { "name": "punctuation.section.bracket.spectre", "match": "[\\[\\]]" },
        { "name": "punctuation.section.paren.spectre", "match": "[()]" }
      ]
    },

    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.spectre",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.spectre",
          "match": "\\b(none|some)\\b"
        }
      ]
    },

    "identifier": {
      "patterns": [
        {
          "comment": "Type names (PascalCase)",
          "name": "entity.name.type.spectre",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "comment": "SCREAMING_SNAKE_CASE constants",
          "name": "constant.other.spectre",
          "match": "\\b[A-Z][A-Z0-9_]{2,}\\b"
        },
        {
          "comment": "Function calls: ident(",
          "name": "entity.name.function.call.spectre",
          "match": "\\b([a-z_][A-Za-z0-9_]*)(?=\\s*\\()"
        },
        {
          "comment": "Plain identifiers / variables",
          "name": "variable.other.spectre",
          "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
